    "@headlessui/react": "1.7.19",
    "@kubernetes/client-node": "1.1.3",
    "@tanstack/react-query": "4.44.0",
    "@tanstack/react-query-devtools": "4.44.0",
    "@tanstack/react-table": "8.21.3",
    "@tauri-apps/api": "^2.4.0",
    "@tauri-apps/plugin-clipboard-manager": "2.3.2",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-fs": "2.5.1",
    "@tauri-apps/plugin-log": "2.8.0",
    "@tauri-apps/plugin-os": "2.3.2",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-shell": "2.3.5",
    "@tauri-apps/plugin-store": "2.4.3",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@types/lodash.debounce": "4.0.9",
    "@xterm/addon-fit": "0.10.0",
    "@xterm/xterm": "5.5.0",
    "compare-versions": "6.1.1",
    "dayjs": "1.11.21",
    "framer-motion": "10.18.0",
    "js-yaml": "4.3.0",
    "jszip": "3.10.1",
    "lodash.debounce": "4.0.8",
    "markdown-to-jsx": "7.7.17",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-error-boundary": "4.1.2",
    "react-hook-form": "7.80.0",
    "react-icons": "4.12.0",
    "react-router": "6.30.4",
    "react-router-dom": "6.30.4",
    "tauri-plugin-store-api": "https://github.com/tauri-apps/tauri-plugin-store#v1",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@eslint/compat": "1.2.7",
    "@eslint/eslintrc": "3.3.0",
    "@eslint/js": "9.22.0",
    "@tanstack/eslint-plugin-query": "4.36.1",
    "@tauri-apps/cli": "2.11.3",
    "@types/node": "24.13.2",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@types/uuid": "9.0.8",
    "@typescript-eslint/eslint-plugin": "8.26.1",
    "@typescript-eslint/parser": "8.26.1",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "9.22.0",
    "eslint-config-prettier": "10.1.1",
    "eslint-config-react-app": "7.0.1",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.19",
    "globals": "16.0.0",
    "prettier": "3.9.0",
    "typescript": "5.9.3",
    "vite": "6.4.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0"
